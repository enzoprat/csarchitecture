---
import type { Project } from "../data/projects";
import { withBase } from "../lib/url";
interface Props { project: Project; index?: number; size?: "tall" | "wide" | "std" }
const { project: p, index = 0, size = "std" } = Astro.props;
const ratio = size === "tall" ? "aspect-[3/4]" : size === "wide" ? "aspect-[16/10]" : "aspect-[4/3]";
---
<a
  href={withBase(`/references/${p.slug}/`)}
  data-astro-prefetch
  data-cursor="Voir le projet"
  data-reveal
  style={`--reveal-delay:${(index % 3) * 90}ms`}
  class="project-card group block"
  aria-label={`${p.title}, ${p.city}`}
>
  <div class={`mask-reveal ${ratio} bg-[color:var(--color-stone)] overflow-hidden`}>
    <img
      src={withBase(p.thumb)}
      alt={`${p.title} — ${p.city}`}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-[1.2s] [transition-timing-function:var(--ease-out-expo)] group-hover:scale-[1.05]"
    />
    <div class="absolute inset-0 bg-[color:var(--color-ink)]/0 group-hover:bg-[color:var(--color-ink)]/10 transition-colors duration-700 z-[1]"></div>
  </div>
  <div class="flex items-start justify-between gap-4 pt-4">
    <div>
      <h3 class="font-serif text-[1.35rem] leading-tight tracking-[-0.01em]">{p.title}</h3>
      <p class="text-[color:var(--color-muted)] text-sm mt-1">{p.city}</p>
    </div>
    <div class="text-right shrink-0">
      <span class="mono block">{p.year}</span>
      <span class="mono block text-[color:var(--color-sage)] mt-1">{p.status}</span>
    </div>
  </div>
  <p class="mono mt-3 text-[color:var(--color-faint)]">{p.categories[0]}</p>
</a>
