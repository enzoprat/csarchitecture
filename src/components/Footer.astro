---
import { nav, site, social } from "../data/site";
import { withBase } from "../lib/url";
const year = new Date().getFullYear();
---
<footer class="relative bg-[color:var(--color-ink)] text-[color:var(--color-paper)] overflow-hidden">
  <div class="blueprint absolute inset-0 opacity-[0.06] pointer-events-none"></div>
  <div class="shell relative pt-24 md:pt-32 pb-10">
    <!-- CTA -->
    <div class="grid12 items-end gap-y-10 pb-16 md:pb-24 border-b border-white/10">
      <div class="col-span-12 lg:col-span-8">
        <p class="mono text-white/40 mb-6">Un lieu, un récit à mettre en espace</p>
        <a href={withBase("/contact/")} class="group block" data-astro-prefetch>
          <span class="display t-h1 block leading-[0.95]">Parlons<br /><span class="display-italic text-[color:var(--color-sage)]">de votre projet.</span></span>
        </a>
      </div>
      <div class="col-span-12 lg:col-span-4 lg:text-right">
        <a href={withBase("/contact/")} class="btn btn-light group" data-astro-prefetch>
          <span>Prendre contact</span>
          <span class="arrow">→</span>
        </a>
      </div>
    </div>

    <!-- Colonnes -->
    <div class="grid12 gap-y-12 pt-14">
      <div class="col-span-12 md:col-span-5">
        <div class="flex items-baseline gap-[0.55rem]">
          <span class="font-serif text-[1.9rem] leading-none tracking-[-0.02em]">CS<span class="text-[color:var(--color-sage)]">.</span></span>
          <span class="mono text-[0.66rem] tracking-[0.32em] uppercase text-white/60">Design</span>
        </div>
        <p class="text-white/50 text-sm mt-4 max-w-xs leading-relaxed">
          Agence pluridisciplinaire de muséographie, scénographie et aménagement d'espaces recevant du public. Des musées aux centres d'interprétation, du concept à la réalisation.
        </p>
        <div class="flex items-center gap-5 mt-6">
          <a href={social.instagram} target="_blank" rel="noopener" class="mono text-white/45 hover:text-white transition-colors link-underline">Instagram</a>
          <a href={social.facebook} target="_blank" rel="noopener" class="mono text-white/45 hover:text-white transition-colors link-underline">Facebook</a>
          <a href={social.linkedin} target="_blank" rel="noopener" class="mono text-white/45 hover:text-white transition-colors link-underline">LinkedIn</a>
        </div>
      </div>
      <nav class="col-span-6 md:col-span-3" aria-label="Pied de page">
        <span class="mono text-white/35 block mb-5">Navigation</span>
        <ul class="space-y-3">
          {nav.map((item) => (
            <li><a href={withBase(item.href)} class="text-white/75 hover:text-white transition-colors text-[0.95rem] link-underline">{item.label}</a></li>
          ))}
        </ul>
      </nav>
      <div class="col-span-6 md:col-span-4">
        <span class="mono text-white/35 block mb-5">Contact</span>
        <address class="not-italic space-y-3 text-white/75 text-[0.95rem]">
          <p>{site.address.street}<br />{site.address.postal} {site.address.city}</p>
          <p><a href={`tel:${site.phoneHref}`} class="link-underline">{site.phone}</a></p>
          <p><a href={`mailto:${site.email}`} class="link-underline">{site.email}</a></p>
        </address>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pt-14 mt-14 border-t border-white/10">
      <p class="mono text-white/35">© {year} {site.legalName} — SIRET {site.siret}</p>
      <p class="mono text-white/35">Muséographie · Scénographie · Aménagement d'espaces</p>
    </div>
  </div>
</footer>
