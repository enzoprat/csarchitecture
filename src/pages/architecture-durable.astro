---
import Base from "../layouts/Base.astro";
import SplitTitle from "../components/SplitTitle.astro";
import { withBase } from "../lib/url";

const pillars = [
  { k: "Bâtiment basse consommation", d: "Concevoir des bâtiments THPE et BBC, bien avant que la réglementation ne l'impose." },
  { k: "Construction bois", d: "Recourir aux matériaux biosourcés pour un bâti sain, chaleureux et bas carbone." },
  { k: "Panneaux solaires", d: "Valoriser l'apport solaire, en actif comme en passif, selon l'orientation du site." },
  { k: "Électricité verte", d: "Réduire l'empreinte du bâtiment jusque dans son exploitation quotidienne." },
  { k: "Écoresponsable", d: "Économiser eau, électricité et énergie primaire à chaque étape du projet." },
  { k: "Environnement", d: "Mesurer l'impact d'une construction sur son site et son voisinage." },
];
---
<Base
  title="Architecture durable — Bâtiments THPE, BBC & RE2020 à Orléans"
  description="CS Architecture conçoit des bâtiments durables et performants : orientation solaire, lumière naturelle, construction bois, rénovation énergétique. Une architecture sobre et responsable à Orléans."
  overlayDark={true}
  image="/images/site/durable-hero.jpg"
>
  <!-- Hero -->
  <section class="relative isolate h-[82svh] min-h-[520px] flex items-end text-[color:var(--color-paper)] overflow-hidden">
    <div class="absolute inset-0 z-0 mask-reveal is-in">
      <img src={withBase("/images/site/durable-hero.jpg")} alt="Architecture durable — bâtiment performant" class="w-full h-[112%] object-cover" data-parallax="0.08" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-t from-[color:var(--color-ink)]/85 via-[color:var(--color-ink)]/20 to-[color:var(--color-ink)]/40"></div>
      <div class="blueprint absolute inset-0 opacity-[0.1]"></div>
    </div>
    <div class="shell relative z-10 pb-14 md:pb-20 w-full">
      <p class="mono text-[color:var(--color-paper)]/70 mb-6" data-reveal>Architecture durable</p>
      <SplitTitle as="h1" class="display t-hero max-w-[15ch]" lines={["Construire avec", { text: "responsabilité.", italic: true, accent: true }]} />
    </div>
  </section>

  <!-- Intro -->
  <section class="shell py-20 md:py-32 grid12 gap-y-10">
    <div class="col-span-12 lg:col-span-7">
      <SplitTitle as="p" class="display t-h1 max-w-[18ch]" stagger={70} lines={["La performance", "énergétique, un", { text: "élément majeur", accent: true }, { text: "de l'acte de construire.", italic: true }]} />
    </div>
    <p class="col-span-12 lg:col-span-4 lg:col-start-9 t-lead text-[color:var(--color-muted)] self-end" data-reveal style="--reveal-delay:140ms">
      Notre expérience, notre volonté et l'application de principes de gestion nous ont permis de concevoir, très tôt, des bâtiments sobres et performants.
    </p>
  </section>

  <!-- Section immersive : coupe animée -->
  <section class="relative bg-[color:var(--color-ink)] text-[color:var(--color-paper)] py-24 md:py-36 overflow-hidden">
    <div class="blueprint absolute inset-0 opacity-[0.07]"></div>
    <div class="shell relative grid12 gap-y-16 items-center">
      <div class="col-span-12 lg:col-span-5">
        <p class="mono text-[color:var(--color-paper)]/50 mb-8" data-reveal>Une conception vertueuse</p>
        <SplitTitle as="h2" class="display t-h2" lines={["Augmenter la", { text: "performance,", accent: true }, "réduire la", { text: "consommation.", italic: true }]} />
        <p class="t-lead text-[color:var(--color-paper)]/80 mt-8 max-w-md" data-reveal style="--reveal-delay:160ms">
          La conception architecturale est avant tout un travail d'équipe avec les bureaux d'études, qui mettent la technique au service de l'esthétique.
        </p>
        <p class="text-[color:var(--color-paper)]/60 mt-6 max-w-md" data-reveal style="--reveal-delay:220ms">
          La gestion des consommations est un point à ne pas négliger : eau, électricité, énergie primaire.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-6 lg:col-start-7" data-plan>
        <svg viewBox="0 0 600 460" class="w-full h-auto" fill="none" aria-hidden="true">
          <circle cx="510" cy="70" r="28" stroke="var(--color-sage)" style="--len:180" class="plan-line"/>
          <g stroke="var(--color-sage)" stroke-width="1" opacity="0.7">
            <line x1="480" y1="100" x2="360" y2="210" style="--len:170" class="plan-line"/>
            <line x1="510" y1="110" x2="420" y2="240" style="--len:150" class="plan-line"/>
          </g>
          <line x1="40" y1="400" x2="560" y2="400" stroke="var(--color-paper)" stroke-opacity="0.5" style="--len:520" class="plan-line"/>
          <path d="M110 400 L110 230 L300 130 L490 230 L490 400" stroke="var(--color-paper)" style="--len:960" class="plan-line" stroke-width="1.4"/>
          <path d="M110 230 L300 130 L490 230" stroke="var(--color-paper)" stroke-opacity="0.6" style="--len:520" class="plan-line"/>
          <line x1="110" y1="315" x2="490" y2="315" stroke="var(--color-paper)" stroke-opacity="0.3" style="--len:380" class="plan-line"/>
          <rect x="145" y="330" width="46" height="60" stroke="var(--color-paper)" stroke-opacity="0.4" style="--len:210" class="plan-line"/>
          <rect x="410" y="330" width="46" height="60" stroke="var(--color-paper)" stroke-opacity="0.4" style="--len:210" class="plan-line"/>
          <path d="M300 380 C300 330 350 330 350 280" stroke="var(--color-sage)" stroke-opacity="0.85" style="--len:150" class="plan-line"/>
          <text x="150" y="185" fill="var(--color-paper)" opacity="0.45" font-family="IBM Plex Mono, monospace" font-size="11">SUD</text>
          <text x="50" y="385" fill="var(--color-sage)" font-family="IBM Plex Mono, monospace" font-size="11">ISOLATION</text>
          <text x="500" y="300" fill="var(--color-paper)" opacity="0.4" font-family="IBM Plex Mono, monospace" font-size="11">R+1</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- Piliers / engagements -->
  <section class="shell py-24 md:py-36">
    <div class="max-w-2xl mb-16">
      <p class="mono mb-6" data-reveal>Engagement environnemental</p>
      <SplitTitle as="h2" class="display t-h1" lines={["Un engagement", { text: "quotidien.", italic: true }]} />
      <p class="t-lead text-[color:var(--color-muted)] mt-8" data-reveal style="--reveal-delay:140ms">
        Notre engagement ne s'arrête pas à la conception : il se développe chaque jour dans notre manière de travailler, par l'économie de ressources et le recyclage mis en place à l'agence.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-[color:var(--color-line)] border border-[color:var(--color-line)]">
      {pillars.map((p, i) => (
        <div class="bg-[color:var(--color-paper)] p-8 md:p-10 group hover:bg-[color:var(--color-paper-2)] transition-colors duration-500" data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
          <span class="mono text-[color:var(--color-sage)]">0{i + 1}</span>
          <h3 class="font-serif text-2xl mt-4 mb-3 group-hover:translate-x-1 transition-transform duration-500">{p.k}</h3>
          <p class="text-[color:var(--color-muted)] text-sm leading-relaxed">{p.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Bande image + citation -->
  <section class="shell pb-24 md:pb-36 grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">
    <div class="md:col-span-6 mask-reveal aspect-[4/3] bg-[color:var(--color-stone)] overflow-hidden">
      <img src={withBase("/images/site/durable.jpg")} alt="Bâtiment durable réalisé par CS Architecture" loading="lazy" class="w-full h-full object-cover" />
    </div>
    <div class="md:col-span-6 flex flex-col justify-center bg-[color:var(--color-paper-2)] p-10 md:p-14">
      <SplitTitle as="p" class="display t-h3 max-w-[22ch]" stagger={70} lines={["« Concevoir avec précision,", { text: "construire avec", italic: true }, { text: "responsabilité. »", accent: true }]} />
      <a href={withBase("/references/")} class="btn group mt-10 self-start" data-astro-prefetch><span>Voir les projets durables</span><span class="arrow">→</span></a>
    </div>
  </section>
</Base>
