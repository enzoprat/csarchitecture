---
import Base from "../layouts/Base.astro";
import SplitTitle from "../components/SplitTitle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
import { withBase } from "../lib/url";

const selection = featuredProjects.slice(0, 4);

const clients = [
  "Musée Champollion, Figeac",
  "Parc national des Calanques",
  "Parc national du Mercantour",
  "Bibliothèques de Toulouse",
  "Ville de Marseille",
  "Département de l'Ariège",
  "Centre des monuments nationaux",
  "CC du Pays de Fénelon",
  "Ville de Blagnac",
  "Ville de Muret",
  "Ville de Toulon",
  "Ville de Cauterets",
  "OT Grand Tourmalet – Pic du Midi",
  "Atelier Robert Doisneau, Paris",
  "CA Hérault Méditerranée",
];

const domains = [
  "Musées",
  "Expositions",
  "Centres d'interprétation",
  "Espaces tourisme",
  "Scénographie",
  "Signalétique",
  "Mobilier sur-mesure",
];

const services = [
  { n: "01", t: "Scénographie d'exposition", d: "Mettre en récit un propos dans l'espace : séquences, parcours et rythme de visite." },
  { n: "02", t: "Muséographie", d: "Traduire un contenu scientifique ou patrimonial en une expérience accessible à tous les publics." },
  { n: "03", t: "Illustration & modélisation 3D", d: "Donner à voir le projet avant sa réalisation, de l'intention au photoréalisme." },
  { n: "04", t: "Design de mobilier & agencement", d: "Concevoir vitrines, socles et dispositifs sur-mesure, dessinés pour le lieu." },
  { n: "05", t: "Étude d'éclairage", d: "Sculpter la lumière pour révéler les œuvres et guider le regard." },
  { n: "06", t: "Création graphique & signalétique", d: "Textes, images et orientation : une identité graphique au service du parcours." },
  { n: "07", t: "Suivi, pilotage & coordination", d: "Piloter la fabrication et le montage (OPC) jusqu'à l'ouverture au public." },
];

const process = [
  { n: "01", t: "Écoute & immersion", d: "Comprendre le lieu, le récit, les collections et les publics visés." },
  { n: "02", t: "Concept & intention scénographique", d: "Définir un parti pris narratif et spatial qui donne du sens à la visite." },
  { n: "03", t: "Muséographie & scénographie", d: "Dessiner le parcours, ses séquences et ses dispositifs de médiation." },
  { n: "04", t: "Illustration & modélisation 3D", d: "Éprouver et partager le projet en volume avant toute fabrication." },
  { n: "05", t: "Mobilier, graphisme & éclairage", d: "Concevoir sur-mesure chaque élément qui compose l'expérience." },
  { n: "06", t: "Suivi, pilotage & coordination", d: "Coordonner les fabricants et piloter le montage sur site (OPC)." },
  { n: "07", t: "Ouverture au public", d: "Livrer un espace vivant, cohérent et prêt à accueillir les visiteurs." },
];
---
<Base
  title="CS Design — Muséographie, scénographie & aménagement d'espaces"
  description="Agence pluridisciplinaire de muséographie et scénographie. CS Design conçoit et réalise musées, expositions, centres d'interprétation et espaces tourisme, du concept à l'ouverture au public."
  overlayDark={true}
  image="/images/site/home-hero.jpg"
>
  <!-- ============ 1 · HERO ============ -->
  <section class="relative isolate min-h-[100svh] flex flex-col justify-end text-[color:var(--color-paper)] overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="mask-reveal is-in w-full h-full">
        <img src={withBase("/images/site/home-hero.jpg")} alt="Scénographie muséale conçue par CS Design" data-parallax="0.08" class="w-full h-[112%] object-cover" fetchpriority="high" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-[color:var(--color-ink)]/85 via-[color:var(--color-ink)]/25 to-[color:var(--color-ink)]/50"></div>
      <div class="blueprint absolute inset-0 opacity-[0.12]"></div>
    </div>

    <div class="shell relative z-10 pb-16 md:pb-24 pt-32 w-full">
      <div class="flex items-center gap-4 mb-8" data-reveal>
        <span class="mono text-[color:var(--color-paper)]/70">Occitanie · France</span>
        <span class="h-px w-16 bg-[color:var(--color-paper)]/30"></span>
        <span class="mono text-[color:var(--color-paper)]/70">Muséographie & scénographie</span>
      </div>

      <SplitTitle
        as="h1"
        class="display t-hero max-w-[16ch]"
        lines={[
          "Mettre en",
          { text: "espace,", accent: true },
          "mettre en",
          { text: "récit.", italic: true },
        ]}
      />

      <div class="grid12 mt-12 items-end gap-y-8">
        <p class="col-span-12 md:col-span-6 lg:col-span-5 t-lead text-[color:var(--color-paper)]/85" data-reveal style="--reveal-delay:200ms">
          Agence pluridisciplinaire de muséographie et d'aménagement d'espaces recevant du public, CS Design conçoit et réalise vos musées, expositions et centres d'interprétation, du premier croquis à l'ouverture au public.
        </p>
        <div class="col-span-12 md:col-span-6 lg:col-span-7 flex flex-wrap gap-4 md:justify-end" data-reveal style="--reveal-delay:320ms">
          <a href={withBase("/references/")} class="btn btn-light group" data-astro-prefetch><span>Voir les réalisations</span><span class="arrow">→</span></a>
          <a href={withBase("/savoir-faire/")} class="btn btn-light group" data-astro-prefetch><span>Nos savoir-faire</span></a>
        </div>
      </div>
    </div>

    <div class="shell relative z-10 pb-6 hidden md:flex justify-between items-center mono text-[color:var(--color-paper)]/50">
      <span>44.1° N · 1.0° E</span>
      <span class="flex items-center gap-2">Défiler <span class="inline-block animate-bounce">↓</span></span>
    </div>
  </section>

  <!-- ============ 2 · MANIFESTE ============ -->
  <section class="shell py-24 md:py-40">
    <p class="mono mb-10" data-reveal>Manifeste</p>
    <SplitTitle
      as="p"
      class="display t-h1 max-w-[20ch]"
      stagger={70}
      lines={[
        "Scénographier un lieu,",
        { text: "c'est composer avec un récit,", italic: true },
        "des collections, une lumière,",
        "des publics et une",
        { text: "émotion.", accent: true },
      ]}
    />

    <div class="grid12 mt-20 gap-y-12 border-t border-[color:var(--color-line)] pt-14">
      {[
        { n: "01", t: "Partir du récit", d: "Chaque projet naît d'un contenu à transmettre : nous en cherchons le fil, la juste narration et le rythme." },
        { n: "02", t: "Penser les publics", d: "Enfants, familles, scolaires, experts : la médiation s'adresse à chacun, sans jamais renoncer à l'exigence." },
        { n: "03", t: "Concevoir sur-mesure", d: "Du mobilier à la lumière, chaque dispositif est dessiné pour le lieu, son propos et son architecture." },
      ].map((p, i) => (
        <div class="col-span-12 md:col-span-4 md:px-8 md:first:pl-0 relative" data-reveal style={`--reveal-delay:${i * 120}ms`}>
          {i > 0 && <span class="hidden md:block absolute left-0 top-1 bottom-1 w-px bg-[color:var(--color-line)]"></span>}
          <span class="mono text-[color:var(--color-sage)]">{p.n}</span>
          <h3 class="font-serif text-2xl mt-4 mb-3">{p.t}</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">{p.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ 3 · DOMAINES ============ -->
  <section class="bg-[color:var(--color-paper-2)] py-24 md:py-36">
    <div class="shell">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 md:mb-24">
        <SplitTitle as="h2" class="display t-h2" lines={["Trois métiers,", { text: "une même écriture.", italic: true }]} />
        <p class="mono max-w-xs">Une réponse globale, du concept muséographique à la réalisation du moindre détail.</p>
      </div>

      <div class="space-y-px">
        {[
          { i: "01", t: "Muséographie", img: "/images/projects/chateau-de-foix-2.jpg", href: "/savoir-faire/", d: "Traduire un contenu patrimonial ou scientifique en un parcours de visite clair, sensible et accessible à tous.", },
          { i: "02", t: "Scénographie & mise en lumière", img: "/images/projects/plongee-au-coeur-des-canyons-1.jpg", href: "/savoir-faire/", d: "Composer l'espace, les séquences et la lumière pour donner corps au récit et éveiller l'émotion.", },
          { i: "03", t: "Mobilier, graphisme & agencement", img: "/images/projects/office-tourisme-grand-tourmalet-1.jpg", href: "/savoir-faire/", d: "Dessiner et fabriquer sur-mesure vitrines, dispositifs, signalétique et mobilier d'accueil.", },
        ].map((e) => (
          <a href={withBase(e.href)} data-astro-prefetch data-cursor="Découvrir" class="expertise group grid grid-cols-12 items-center gap-4 py-8 md:py-10 border-t border-[color:var(--color-line)] last:border-b" data-reveal>
            <span class="mono col-span-2 md:col-span-1 text-[color:var(--color-sage)]">{e.i}</span>
            <div class="col-span-10 md:col-span-4">
              <h3 class="font-serif text-[clamp(1.6rem,3vw,2.6rem)] leading-tight tracking-[-0.01em] transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:translate-x-2">{e.t}</h3>
            </div>
            <div class="hidden md:block col-span-3 overflow-hidden">
              <div class="h-24 w-full max-w-[240px] overflow-hidden bg-[color:var(--color-stone)] opacity-0 -translate-x-4 transition-all duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:opacity-100 group-hover:translate-x-0">
                <img src={withBase(e.img)} alt={e.t} loading="lazy" class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-[1.4s]" />
              </div>
            </div>
            <p class="col-span-12 md:col-span-3 text-[color:var(--color-muted)] text-sm leading-relaxed mt-2 md:mt-0">{e.d}</p>
            <span class="hidden md:flex col-span-1 justify-end text-2xl arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 4 · RÉFÉRENCES ============ -->
  <section class="shell py-24 md:py-40">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <p class="mono mb-6" data-reveal>Réalisations sélectionnées</p>
        <SplitTitle as="h2" class="display t-h1" lines={["Des lieux qui", { text: "racontent et émeuvent.", italic: true }]} />
      </div>
      <a href={withBase("/references/")} class="btn group self-start md:self-end" data-astro-prefetch><span>Toutes les réalisations</span><span class="arrow">→</span></a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-6 gap-y-14">
      <div class="md:col-span-7"><ProjectCard project={selection[0]} index={0} size="wide" /></div>
      <div class="md:col-span-5 md:mt-16"><ProjectCard project={selection[1]} index={1} size="std" /></div>
      <div class="md:col-span-5"><ProjectCard project={selection[2]} index={2} size="std" /></div>
      <div class="md:col-span-7 md:-mt-10"><ProjectCard project={selection[3]} index={0} size="wide" /></div>
    </div>
  </section>

  <!-- ============ 5 · SAVOIR-FAIRE ============ -->
  <section class="relative bg-[color:var(--color-ink)] text-[color:var(--color-paper)] py-24 md:py-40 overflow-hidden">
    <div class="blueprint absolute inset-0 opacity-[0.07]"></div>
    <div class="shell relative">
      <div class="grid12 gap-y-14">
        <div class="col-span-12 lg:col-span-4">
          <p class="mono text-[color:var(--color-paper)]/50 mb-8" data-reveal>Savoir-faire</p>
          <SplitTitle as="h2" class="display t-h1" lines={["Sept métiers", { text: "réunis", accent: true }, { text: "sous un même toit.", italic: true }]} />
          <p class="t-lead text-[color:var(--color-paper)]/80 mt-8 max-w-md" data-reveal style="--reveal-delay:160ms">
            De la conception au montage, l'ensemble des compétences d'un projet muséographique sont réunies en interne, pour une cohérence sans faille et un interlocuteur unique.
          </p>
          <a href={withBase("/savoir-faire/")} class="btn btn-light group mt-10" data-astro-prefetch><span>Explorer nos savoir-faire</span><span class="arrow">→</span></a>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="border-t border-white/10">
            {services.map((s, i) => (
              <div class="grid grid-cols-12 gap-4 items-baseline py-6 border-b border-white/10" data-reveal style={`--reveal-delay:${(i % 4) * 70}ms`}>
                <span class="mono text-[color:var(--color-sage)] col-span-2 md:col-span-1">{s.n}</span>
                <h3 class="font-serif text-xl md:text-2xl col-span-10 md:col-span-5">{s.t}</h3>
                <p class="text-[color:var(--color-paper)]/60 text-sm col-span-12 md:col-span-6 mt-1 md:mt-0 leading-relaxed">{s.d}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 6 · CONCEPT À LA RÉALISATION ============ -->
  <section class="py-24 md:py-40 bg-[color:var(--color-paper)]">
    <div class="shell">
      <div class="grid12 gap-y-14 items-center">
        <div class="col-span-12 lg:col-span-6 order-2 lg:order-1">
          <div class="relative">
            <div class="mask-reveal aspect-[4/3] bg-[color:var(--color-stone)] overflow-hidden" data-parallax="0.04">
              <img src={withBase("/images/projects/salon-occitanie-innov-2023-2.jpg")} alt="Scénographie en cours de réalisation par CS Design" loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-10 -right-4 md:-right-10 w-1/2 mask-reveal aspect-[4/3] bg-[color:var(--color-sand)] border-4 border-[color:var(--color-paper)] shadow-sm overflow-hidden" data-parallax="0.12">
              <img src={withBase("/images/projects/salon-occitanie-innov-2023-3.jpg")} alt="Dispositif scénographique CS Design" loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -top-6 -left-4 hidden md:flex items-center gap-2 mono bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-4 py-2">
              <span class="h-1.5 w-1.5 rounded-full bg-[color:var(--color-sage)]"></span>Conception & réalisation
            </div>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 order-1 lg:order-2">
          <p class="mono mb-8" data-reveal>Une agence intégrée</p>
          <SplitTitle as="h2" class="display t-h1" lines={["Du concept", { text: "à l'ouverture", accent: true }, { text: "au public.", italic: true }]} />
          <p class="t-lead text-[color:var(--color-muted)] mt-8" data-reveal style="--reveal-delay:160ms">
            Nous concevons vos projets d'aménagement et vous accompagnons dans leur réalisation, sans rupture entre l'idée et le chantier.
          </p>
          <div class="mt-10 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)]" data-reveal style="--reveal-delay:220ms">
            {[["Conception intégrée", "Muséographie, graphisme et mobilier dessinés ensemble."], ["Modélisation 3D", "Éprouver et partager le projet avant sa fabrication."], ["Pilotage & coordination", "Un suivi OPC jusqu'au montage sur site."]].map(([t, d]) => (
              <div class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6">
                <span class="font-serif text-lg sm:w-2/5">{t}</span>
                <span class="text-[color:var(--color-muted)] text-sm sm:flex-1">{d}</span>
              </div>
            ))}
          </div>
          <a href={withBase("/savoir-faire/")} class="btn group mt-10" data-astro-prefetch><span>Notre méthode</span><span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 7 · AGENCE ============ -->
  <section class="bg-[color:var(--color-paper-2)] py-24 md:py-40">
    <div class="shell grid12 gap-y-14 items-center">
      <div class="col-span-12 lg:col-span-5">
        <div class="mask-reveal aspect-[4/5] bg-[color:var(--color-stone)] overflow-hidden">
          <img src={withBase("/images/site/agence.jpg")} alt="L'agence CS Design — muséographie et scénographie" loading="lazy" data-parallax="0.06" class="w-full h-[110%] object-cover" />
        </div>
      </div>
      <div class="col-span-12 lg:col-span-6 lg:col-start-7">
        <p class="mono mb-8" data-reveal>L'agence</p>
        <SplitTitle as="h2" class="display t-h1" lines={["Une équipe", { text: "pluridisciplinaire", italic: true }, "et engagée."]} />
        <p class="t-lead text-[color:var(--color-muted)] mt-8 max-w-xl" data-reveal style="--reveal-delay:140ms">
          Fondée par Claire Simonet, scénographe-designer, CS Design réunit muséographes, designers et pilotes de projet autour d'une conviction : chaque lieu mérite un récit sur-mesure.
        </p>
        <div class="grid grid-cols-3 gap-6 mt-12 border-t border-[color:var(--color-line)] pt-10" data-reveal style="--reveal-delay:220ms">
          {[["7", "domaines de savoir-faire"], ["100%", "projets sur-mesure"], ["3", "régions d'intervention"]].map(([k, v]) => (
            <div><span class="display text-[clamp(2.2rem,5vw,3.5rem)] block leading-none">{k}</span><span class="mono mt-2 block max-w-[14ch]">{v}</span></div>
          ))}
        </div>
        <a href={withBase("/agence/")} class="btn group mt-12" data-astro-prefetch><span>Rencontrer l'équipe</span><span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ 8 · MÉTHODE ============ -->
  <section class="shell py-24 md:py-40">
    <div class="max-w-2xl mb-16 md:mb-24">
      <p class="mono mb-6" data-reveal>Notre méthode</p>
      <SplitTitle as="h2" class="display t-h1" lines={["Du croquis", { text: "à l'ouverture.", italic: true }]} />
    </div>

    <ol class="relative border-l border-[color:var(--color-line)] ml-2 md:ml-0">
      {process.map((step, i) => (
        <li class="relative pl-8 md:pl-0 md:grid md:grid-cols-12 md:gap-6 py-8 md:py-10 border-b border-[color:var(--color-line)] group" data-reveal style={`--reveal-delay:${i * 60}ms`}>
          <span class="absolute -left-[5px] top-10 md:hidden h-2 w-2 rounded-full bg-[color:var(--color-sage)]"></span>
          <span class="mono text-[color:var(--color-sage)] md:col-span-1">{step.n}</span>
          <h3 class="font-serif text-[clamp(1.5rem,2.6vw,2.2rem)] leading-tight md:col-span-6 mt-1 md:mt-0 transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] group-hover:md:translate-x-2">{step.t}</h3>
          <p class="text-[color:var(--color-muted)] md:col-span-5 mt-2 md:mt-1 leading-relaxed">{step.d}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============ 9 · ILS NOUS FONT CONFIANCE ============ -->
  <section class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] py-20 md:py-28 overflow-hidden">
    <div class="shell">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <SplitTitle as="h2" class="display t-h2 max-w-[16ch]" lines={["Ils nous", { text: "font confiance.", italic: true }]} />
        <p class="mono text-[color:var(--color-paper)]/50 max-w-xs">Collectivités, musées, parcs nationaux et institutions culturelles nous confient leurs projets partout en France.</p>
      </div>
    </div>
    <div class="relative select-none" aria-hidden="true">
      <div class="marquee-track">
        {[...domains, ...domains].map((m) => (
          <span class="display text-[clamp(2rem,6vw,4.5rem)] text-[color:var(--color-paper)]/20 px-8 flex items-center gap-8">{m}<span class="text-[color:var(--color-sage)]/60 text-xl">✳</span></span>
        ))}
      </div>
    </div>
    <div class="shell mt-14">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10 border border-white/10">
        {clients.map((c, i) => (
          <li class="bg-[color:var(--color-ink)] p-5 md:p-6 flex items-baseline gap-4" data-reveal style={`--reveal-delay:${(i % 3) * 80}ms`}>
            <span class="mono text-[color:var(--color-sage)] shrink-0">{String(i + 1).padStart(2, "0")}</span>
            <p class="font-serif text-lg leading-tight">{c}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
