---
import Base from "../layouts/Base.astro";
import SplitTitle from "../components/SplitTitle.astro";
import { withBase } from "../lib/url";

const steps = [
  { k: "Conception à exécution", d: "Une seule maquette porte le projet, du parti architectural jusqu'au chantier." },
  { k: "Collaboration BE", d: "Structure, fluides, thermique : les études se coordonnent autour d'un modèle commun." },
  { k: "BIM Serveur · GED · Viewer", d: "Des outils qui autorisent le partage collaboratif des maquettes numériques." },
  { k: "Coordination des maquettes", d: "La cohérence entre disciplines est vérifiée en continu, avant le chantier." },
  { k: "Maintenance & exploitation", d: "Une description précise et indexée du bâti pour surveiller et anticiper." },
  { k: "Anticipation des usages", d: "Le modèle prépare la vie du bâtiment et facilite sa gestion future." },
];
---
<Base
  title="Maquette numérique BIM — Conception & coordination à Orléans"
  description="CS Architecture conçoit tous ses projets en maquette numérique BIM, de la conception à l'exécution : coordination des bureaux d'études, BIM serveur, GED et viewer. Le BIM au service de la maîtrise du projet."
  overlayDark={false}
  image="/images/site/bim-1.png"
>
  <!-- Hero clair, technique -->
  <section class="relative isolate pt-36 md:pt-48 pb-16 overflow-hidden">
    <div class="blueprint absolute inset-0 opacity-[0.5] z-0"></div>
    <div class="shell relative z-10">
      <div class="flex items-center gap-4 mb-8" data-reveal>
        <span class="mono">Maquette numérique</span>
        <span class="h-px w-16 bg-[color:var(--color-line)]"></span>
        <span class="mono text-[color:var(--color-sage)]">BIM</span>
      </div>
      <SplitTitle as="h1" class="display t-hero max-w-[15ch]" lines={["La maquette", { text: "numérique,", accent: true }, { text: "pour tous.", italic: true }]} />
      <p class="t-lead text-[color:var(--color-muted)] max-w-2xl mt-10" data-reveal style="--reveal-delay:160ms">
        De la conception à l'exécution, tous les projets de l'agence sont réalisés depuis plusieurs années en maquette numérique. Le BIM comme outil de coordination, de lisibilité et de maîtrise.
      </p>
    </div>
  </section>

  <!-- Effet de calques -->
  <section class="shell py-16 md:py-28">
    <div class="relative h-[380px] sm:h-[520px] md:h-[640px]" id="layers">
      <div class="layer absolute inset-0 mask-reveal bg-[color:var(--color-stone)] overflow-hidden" data-parallax="0.02">
        <img src={withBase("/images/site/bim-1.png")} alt="Maquette numérique BIM d'un bâtiment" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="layer absolute inset-0 pointer-events-none" data-parallax="0.08">
        <svg viewBox="0 0 1000 640" preserveAspectRatio="xMidYMid slice" class="w-full h-full" fill="none" aria-hidden="true">
          <g stroke="var(--color-paper)" stroke-opacity="0.5" stroke-width="1">
            <path d="M120 520 L400 360 L680 520" class="plan-line" style="--len:700"/>
            <path d="M400 360 L400 200" class="plan-line" style="--len:200"/>
            <path d="M260 440 L540 280" class="plan-line" style="--len:400"/>
            <rect x="320" y="300" width="160" height="120" class="plan-line" style="--len:600"/>
          </g>
        </svg>
      </div>
      <div class="layer absolute -bottom-8 right-4 md:right-10 w-[46%] max-w-[380px] mask-reveal aspect-[4/3] bg-[color:var(--color-sand)] border-4 border-[color:var(--color-paper)] shadow-sm overflow-hidden" data-parallax="0.16">
        <img src={withBase("/images/site/bim-2.png")} alt="Coordination de maquette BIM — site industriel" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="absolute top-4 left-4 mono bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-4 py-2 flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[color:var(--color-sage)]"></span>Modèle fédéré · multi-disciplines
      </div>
    </div>
  </section>

  <!-- Convictions -->
  <section class="shell py-16 md:py-24 grid12 gap-y-10">
    <div class="col-span-12 lg:col-span-5">
      <p class="mono mb-6" data-reveal>Notre conviction</p>
      <SplitTitle as="h2" class="display t-h2" lines={["Un pari pris", { text: "très tôt.", italic: true }]} />
    </div>
    <p class="col-span-12 lg:col-span-6 lg:col-start-7 t-lead text-[color:var(--color-muted)] self-center" data-reveal style="--reveal-delay:120ms">
      Nous avons parié très tôt sur le BIM et l'avons intégré à nos méthodes. Nos études sont systématiquement réalisées suivant ce processus, gage de cohérence entre les informations des différentes maquettes réalisées.
    </p>
  </section>

  <!-- Étapes BIM -->
  <section class="bg-[color:var(--color-paper-2)] py-24 md:py-32">
    <div class="shell">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16">
        {steps.map((s, i) => (
          <div class="flex gap-6 py-7 border-t border-[color:var(--color-line)] group" data-reveal style={`--reveal-delay:${(i % 2) * 100}ms`}>
            <span class="mono text-[color:var(--color-sage)] pt-2">0{i + 1}</span>
            <div>
              <h3 class="font-serif text-2xl mb-2 group-hover:translate-x-1 transition-transform duration-500">{s.k}</h3>
              <p class="text-[color:var(--color-muted)] text-sm leading-relaxed">{s.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Exemple + citation -->
  <section class="shell py-24 md:py-32 grid12 gap-y-12 items-center">
    <div class="col-span-12 lg:col-span-6 mask-reveal aspect-[16/10] bg-[color:var(--color-stone)] overflow-hidden">
      <img src={withBase("/images/site/dessin-dao.jpg")} alt="Dessin technique et maquette numérique" loading="lazy" class="w-full h-full object-cover" data-parallax="0.04" />
    </div>
    <div class="col-span-12 lg:col-span-5 lg:col-start-8">
      <p class="mono mb-6" data-reveal>Exemple de maquette BIM</p>
      <p class="t-lead text-[color:var(--color-ink)] leading-relaxed" data-reveal style="--reveal-delay:100ms">
        La maquette numérique d'un site industriel de production de cosmétiques devient un véritable atout pour les services généraux de l'entreprise : la description précise et indexée du bâti permet surveillance et anticipation.
      </p>
      <a href={withBase("/references/")} class="btn group mt-10" data-astro-prefetch><span>Voir nos réalisations</span><span class="arrow">→</span></a>
    </div>
  </section>
</Base>
