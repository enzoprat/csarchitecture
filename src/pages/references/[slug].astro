---
import Base from "../../layouts/Base.astro";
import SplitTitle from "../../components/SplitTitle.astro";
import { projects } from "../../data/projects";
import { withBase } from "../../lib/url";

export function getStaticPaths() {
  return projects.map((p, i) => {
    const next = projects[(i + 1) % projects.length];
    const prev = projects[(i - 1 + projects.length) % projects.length];
    return { params: { slug: p.slug }, props: { project: p, next, prev } };
  });
}

const { project: p, next, prev } = Astro.props;
const meta = [
  ["Ville", p.city],
  ["Programme", p.program],
  ["Surface", p.surface],
  ["Année", p.year],
  ["Statut", p.status],
  ["Intervention", p.intervention],
];

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: p.title,
  about: p.program,
  locationCreated: p.city,
  dateCreated: p.year,
  creator: { "@type": "Organization", name: "CS Design" },
};
---
<Base
  title={`${p.title} — ${p.city}`}
  description={`${p.title} à ${p.city} : ${p.excerpt} Projet de ${p.categories[0].toLowerCase()} conçu et réalisé par CS Design, agence de muséographie et scénographie.`}
  overlayDark={true}
  image={p.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(projectSchema)} is:inline />

  <!-- Hero -->
  <section class="relative isolate h-[86svh] min-h-[520px] flex items-end text-[color:var(--color-paper)] overflow-hidden">
    <div class="absolute inset-0 z-0 mask-reveal is-in">
      <img src={withBase(p.hero)} alt={`${p.title}, ${p.city}`} class="w-full h-[112%] object-cover" data-parallax="0.08" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-t from-[color:var(--color-ink)]/85 via-transparent to-[color:var(--color-ink)]/30"></div>
    </div>
    <div class="shell relative z-10 pb-14 md:pb-20 w-full">
      <div class="flex flex-wrap items-center gap-3 mb-6" data-reveal>
        {p.categories.map((c) => <span class="mono text-[color:var(--color-paper)]/70 border border-white/25 px-3 py-1">{c}</span>)}
      </div>
      <SplitTitle as="h1" class="display t-hero max-w-[16ch]" lines={p.title.split(" — ").length > 1 ? p.title.split(" — ") : [p.title]} />
      <p class="mono text-[color:var(--color-paper)]/70 mt-6">{p.city} · {p.year} · {p.status}</p>
    </div>
  </section>

  <!-- Intro + méta -->
  <section class="shell py-20 md:py-28 grid12 gap-y-12">
    <div class="col-span-12 lg:col-span-7">
      <SplitTitle as="p" class="display t-h2 max-w-[20ch]" stagger={80} lines={[p.excerpt]} />
    </div>
    <dl class="col-span-12 lg:col-span-4 lg:col-start-9 grid grid-cols-2 gap-y-8 gap-x-6 border-t border-[color:var(--color-line)] pt-8 self-start" data-reveal>
      {meta.map(([k, v]) => (
        <div>
          <dt class="mono mb-2">{k}</dt>
          <dd class="font-serif text-lg leading-tight">{v}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- Galerie 1 -->
  <section class="shell pb-8">
    <div class="mask-reveal aspect-[16/9] bg-[color:var(--color-stone)] overflow-hidden">
      <img src={withBase(p.gallery[1] ?? p.hero)} alt={`${p.title} — vue 1`} loading="lazy" class="w-full h-full object-cover" data-parallax="0.04" />
    </div>
  </section>

  <!-- Contexte / Réponse -->
  <section class="shell py-16 md:py-24">
    <div class="grid12 gap-y-14">
      <div class="col-span-12 md:col-span-6 lg:col-span-5">
        <p class="mono mb-6" data-reveal>Contexte</p>
        <p class="t-lead text-[color:var(--color-ink)] leading-relaxed" data-reveal style="--reveal-delay:80ms">{p.context}</p>
      </div>
      <div class="col-span-12 md:col-span-6 lg:col-span-5 lg:col-start-8">
        <p class="mono mb-6" data-reveal>Réponse scénographique</p>
        <p class="t-lead text-[color:var(--color-muted)] leading-relaxed" data-reveal style="--reveal-delay:80ms">{p.response}</p>
      </div>
    </div>
  </section>

  <!-- Galerie 2 (deux images) -->
  <section class="shell pb-16 md:pb-24 grid grid-cols-1 md:grid-cols-12 gap-6">
    <div class="md:col-span-7 mask-reveal aspect-[4/3] bg-[color:var(--color-stone)] overflow-hidden">
      <img src={withBase(p.gallery[2] ?? p.hero)} alt={`${p.title} — vue 2`} loading="lazy" class="w-full h-full object-cover" />
    </div>
    <div class="md:col-span-5 flex flex-col justify-center bg-[color:var(--color-paper-2)] p-8 md:p-10">
      <p class="mono mb-6">Matières, lumière & détails</p>
      <p class="font-serif text-xl md:text-2xl leading-snug">{p.matter}</p>
    </div>
  </section>

  {p.gallery[3] && (
    <section class="shell pb-16 md:pb-24">
      <div class="mask-reveal aspect-[16/9] bg-[color:var(--color-stone)] overflow-hidden">
        <img src={withBase(p.gallery[3])} alt={`${p.title} — vue 3`} loading="lazy" class="w-full h-full object-cover" data-parallax="0.04" />
      </div>
    </section>
  )}

  <!-- Données clés -->
  <section class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] py-20 md:py-28">
    <div class="shell">
      <p class="mono text-[color:var(--color-paper)]/50 mb-12" data-reveal>Données clés</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-12 gap-x-6">
        {p.data.map((d, i) => (
          <div data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="display text-[clamp(2rem,5vw,3.5rem)] block leading-none">{d.value}</span>
            <span class="mono text-[color:var(--color-paper)]/40 mt-3 block">{d.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Navigation prev / next -->
  <nav class="shell py-16 md:py-24 grid grid-cols-2 gap-6" aria-label="Autres projets">
    <a href={withBase(`/references/${prev.slug}/`)} data-astro-prefetch class="group">
      <span class="mono flex items-center gap-2 mb-3"><span class="arrow inline-block group-hover:-translate-x-1 transition-transform">←</span> Précédent</span>
      <span class="font-serif text-xl md:text-3xl group-hover:text-[color:var(--color-sage)] transition-colors">{prev.title}</span>
    </a>
    <a href={withBase(`/references/${next.slug}/`)} data-astro-prefetch class="group text-right">
      <span class="mono flex items-center justify-end gap-2 mb-3">Suivant <span class="arrow inline-block">→</span></span>
      <span class="font-serif text-xl md:text-3xl group-hover:text-[color:var(--color-sage)] transition-colors">{next.title}</span>
    </a>
  </nav>

  <div class="shell pb-24 text-center">
    <a href={withBase("/references/")} class="btn group" data-astro-prefetch><span>Toutes les réalisations</span></a>
  </div>
</Base>
