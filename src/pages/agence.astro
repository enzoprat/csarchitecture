---
import Base from "../layouts/Base.astro";
import SplitTitle from "../components/SplitTitle.astro";
import { withBase } from "../lib/url";

const team = [
  {
    name: "Claire Simonet",
    role: "Scénographe-designer · Fondatrice",
    img: "/images/team/claire.jpg",
    bio: "Formée à la scénographie à l'University of Lincoln (Royaume-Uni), elle fonde CS Design et enseigne la muséographie au sein d'un Master de l'Université de Toulouse, à Cahors.",
  },
  {
    name: "Christian Sintes",
    role: "Chargé d'affaires · OPC",
    img: "/images/team/christian.jpg",
    bio: "Fort de quinze ans d'expérience en pilotage et coordination, il assure le suivi, l'ordonnancement et la coordination des chantiers jusqu'au montage.",
  },
  {
    name: "Camille Provendier",
    role: "Muséographe partenaire",
    img: "/images/team/camille.jpg",
    bio: "Géographe spécialisée en médiation environnementale, elle apporte une lecture sensible des territoires et du vivant au service des contenus.",
  },
];

const values = [
  ["Écoute", "Comprendre le lieu, le récit et les publics avant de dessiner quoi que ce soit."],
  ["Sur-mesure", "Chaque dispositif, mobilier ou graphisme est conçu pour son contexte, jamais dupliqué."],
  ["Éco-conception", "Matériaux justes, réemploi et sobriété : concevoir des expositions responsables."],
];
---
<Base
  title="L'agence — CS Design, muséographie & scénographie"
  description="CS Design est une agence pluridisciplinaire de muséographie et d'aménagement d'espaces recevant du public, fondée par Claire Simonet, scénographe-designer."
  overlayDark={false}
  image="/images/site/agence.jpg"
>
  <!-- Hero éditorial -->
  <section class="shell pt-36 md:pt-48 pb-16">
    <p class="mono mb-8" data-reveal>L'agence</p>
    <SplitTitle as="h1" class="display t-hero max-w-[16ch]" lines={["Une agence", { text: "pluridisciplinaire", italic: true }, { text: "du récit.", accent: true }]} />
    <div class="grid12 mt-12 gap-y-8">
      <p class="col-span-12 lg:col-span-6 t-lead text-[color:var(--color-muted)]" data-reveal style="--reveal-delay:160ms">
        CS Design est une agence pluridisciplinaire dans le domaine de la muséographie et de l'aménagement d'espaces recevant du public. Nous concevons vos projets d'aménagement et vous accompagnons dans leur réalisation.
      </p>
      <p class="col-span-12 lg:col-span-5 lg:col-start-8 t-lead text-[color:var(--color-ink)] self-end" data-reveal style="--reveal-delay:240ms">
        Du concept muséographique au montage sur site, l'ensemble des compétences est réuni en interne : muséographie, scénographie, graphisme, mobilier et coordination.
      </p>
    </div>
  </section>

  <!-- Grande image -->
  <section class="shell pb-20 md:pb-28">
    <div class="mask-reveal aspect-[16/9] bg-[color:var(--color-stone)] overflow-hidden">
      <img src={withBase("/images/site/agence.jpg")} alt="L'agence CS Design — muséographie et scénographie" loading="lazy" class="w-full h-[110%] object-cover" data-parallax="0.06" />
    </div>
  </section>

  <!-- Valeurs -->
  <section class="shell pb-24 md:pb-32">
    <div class="grid12 border-t border-[color:var(--color-line)] pt-14 gap-y-12">
      {values.map(([t, d], i) => (
        <div class="col-span-12 md:col-span-4 md:px-8 md:first:pl-0 relative" data-reveal style={`--reveal-delay:${i * 120}ms`}>
          {i > 0 && <span class="hidden md:block absolute left-0 top-1 bottom-1 w-px bg-[color:var(--color-line)]"></span>}
          <span class="mono text-[color:var(--color-sage)]">0{i + 1}</span>
          <h3 class="font-serif text-2xl mt-4 mb-3">{t}</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Équipe -->
  <section class="bg-[color:var(--color-paper-2)] py-24 md:py-32">
    <div class="shell">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <SplitTitle as="h2" class="display t-h1" lines={["L'équipe", { text: "CS Design.", italic: true }]} />
        <p class="mono max-w-xs">Scénographe, muséographe et pilote de projet réunis autour d'une même exigence.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12 max-w-5xl">
        {team.map((m, i) => (
          <div class="member group" data-reveal style={`--reveal-delay:${(i % 3) * 100}ms`}>
            <div class="mask-reveal aspect-[3/4] bg-[color:var(--color-stone)] overflow-hidden relative">
              <img src={withBase(m.img)} alt={m.name} loading="lazy" class="w-full h-full object-cover grayscale-[0.15] transition-all duration-[1.2s] group-hover:grayscale-0 group-hover:scale-[1.04]" />
              <div class="absolute inset-0 bg-[color:var(--color-ink)]/85 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-5 z-[3]">
                <p class="text-[color:var(--color-paper)]/90 text-sm leading-relaxed translate-y-3 group-hover:translate-y-0 transition-transform duration-500">{m.bio}</p>
              </div>
            </div>
            <h3 class="font-serif text-xl mt-4 leading-tight">{m.name}</h3>
            <p class="mono mt-1 text-[color:var(--color-faint)]">{m.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Enseignement & transmission -->
  <section class="shell py-24 md:py-32">
    <div class="grid12 gap-y-12 items-center">
      <div class="col-span-12 lg:col-span-5">
        <p class="mono mb-6" data-reveal>Transmission</p>
        <SplitTitle as="h2" class="display t-h1" lines={["Concevoir,", { text: "et transmettre.", italic: true }]} />
      </div>
      <p class="col-span-12 lg:col-span-6 lg:col-start-7 t-lead text-[color:var(--color-muted)] leading-relaxed" data-reveal style="--reveal-delay:140ms">
        Au-delà de la commande, CS Design partage sa pratique : Claire Simonet enseigne la muséographie en Master à l'Université de Toulouse. Cet ancrage pédagogique nourrit une conception rigoureuse, à jour des enjeux de médiation, d'accessibilité et d'éco-conception.
      </p>
    </div>
  </section>
</Base>
